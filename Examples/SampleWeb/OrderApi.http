###############################################################################
# FunctionalDDD Order API Tests
# 
# Tests across all three sample implementations:
# 1. SampleMinimalApi (Port 5001) - Minimal API with source generation
# 2. SampleMinimalApiNoAot (Port 5002) - Minimal API with reflection fallback
# 3. SampleWebApplication (Port 5003) - MVC Controllers
#
# To switch between implementations, use the environment selector.
# Available environments: MinimalApi, MinimalApiNoAot, WebApplication
###############################################################################

###############################################################################
# Products — CRUD with RFC 9110 (ETags, Pagination, Specifications)
###############################################################################

### List products — paginated (200 OK or 206 Partial Content + Content-Range)
GET {{host}}/products?page=0&pageSize=3
Accept: application/json

### List products — Specification filtering (inStock + price range)
GET {{host}}/products?inStock=true&minPrice=50&maxPrice=200
Accept: application/json

### Get product by ID (returns ETag + Last-Modified headers)
# Copy a product ID from the list response above
GET {{host}}/products/{{productId}}
Accept: application/json

### Conditional GET — If-None-Match → 304 Not Modified
# Copy the ETag from the GET response above
GET {{host}}/products/{{productId}}
Accept: application/json
If-None-Match: "{{etag}}"

### Create product (201 Created + ETag + Location)
POST {{host}}/products
Content-Type: application/json
Accept: application/json

{
  "name": "Ergonomic Keyboard",
  "price": 129.99,
  "stock": 40
}

### Update product — optimistic concurrency with If-Match
# Copy the ETag from the create or GET response
PUT {{host}}/products/{{productId}}
Content-Type: application/json
Accept: application/json
If-Match: "{{etag}}"

{
  "price": 119.99
}

### Delete product (204 No Content)
DELETE {{host}}/products/{{productId}}

### Legacy redirect (301 Moved Permanently → /products/{id})
GET {{host}}/products/legacy/{{productId}}
Accept: application/json

### Create product — validation error (400 Bad Request)
POST {{host}}/products
Content-Type: application/json
Accept: application/json

{
  "name": "",
  "price": -10,
  "stock": -5
}

###############################################################################
# Orders — Async ROP Chains, Authorization, State Machine
###############################################################################

### Create order (Ensure → Bind → TraverseAsync → CheckAsync)
# Use product IDs from the list response
POST {{host}}/orders
Content-Type: application/json
Accept: application/json

{
  "customerId": "11111111-1111-1111-1111-111111111111",
  "lines": [
    { "productId": "{{productId1}}", "quantity": 2 },
    { "productId": "{{productId2}}", "quantity": 1 }
  ]
}

### Get order by ID (conditional GET with ETag)
GET {{host}}/orders/{{orderId}}
Accept: application/json

### Confirm order (BindAsync → CheckAsync → payment → notify + auth)
# Set X-Test-Actor header for DevelopmentActorProvider
POST {{host}}/orders/{{orderId}}/confirm
X-Test-Actor: {"id":"user1","permissions":["orders:write"]}

### Confirm order — missing permission (403 Forbidden)
POST {{host}}/orders/{{orderId}}/confirm
X-Test-Actor: {"id":"user2","permissions":["orders:read"]}

### Cancel order (RecoverOnFailureAsync demo)
POST {{host}}/orders/{{orderId}}/cancel
X-Test-Actor: {"id":"user1","permissions":["orders:write"]}

### Receipt redirect (303 See Other → GET /orders/{id})
POST {{host}}/orders/{{orderId}}/receipt

### Create order — validation errors (400 Bad Request)
POST {{host}}/orders
Content-Type: application/json
Accept: application/json

{
  "customerId": "not-a-guid",
  "lines": [
    { "productId": "also-not-a-guid", "quantity": 1 }
  ]
}

### Create order — empty lines (400 Bad Request)
POST {{host}}/orders
Content-Type: application/json
Accept: application/json

{
  "customerId": "11111111-1111-1111-1111-111111111111",
  "lines": []
}

###############################################################################
# Dashboard — ParallelAsync / WhenAllAsync
###############################################################################

### Get dashboard (concurrent product count + order count + revenue)
GET {{host}}/dashboard
Accept: application/json

###############################################################################
# Order States — RequiredEnum with rich behavior
###############################################################################

### Get all order states
GET {{host}}/orders/states
Accept: application/json

### Get state by name (route binding)
GET {{host}}/orders/states/Draft
Accept: application/json

### Get state — case insensitive
GET {{host}}/orders/states/CONFIRMED
Accept: application/json

### Get state — invalid (400 Bad Request)
GET {{host}}/orders/states/InvalidState
Accept: application/json

### Filter orders by state (query string binding)
GET {{host}}/orders/filter?state=Draft
Accept: application/json

### Filter — invalid state (400 Bad Request)
GET {{host}}/orders/filter?state=BadState
Accept: application/json

###############################################################################
# Order Update — RequiredEnum + Maybe<T> in JSON body
###############################################################################

### Update order — with Maybe<FirstName> assignedTo
POST {{host}}/orders/update
Content-Type: application/json
Accept: application/json

{
    "state": "Confirmed",
    "assignedTo": "Alice",
    "notes": "Assigned to Alice for processing"
}

### Update order — assignedTo omitted (Maybe.None, no error)
POST {{host}}/orders/update
Content-Type: application/json
Accept: application/json

{
    "state": "Shipped",
    "notes": "No agent assigned — field omitted"
}

### Update order — assignedTo null (Maybe.None, no error)
POST {{host}}/orders/update
Content-Type: application/json
Accept: application/json

{
    "state": "Delivered",
    "assignedTo": null,
    "notes": "No agent assigned — explicitly null"
}

### Update order — assignedTo invalid (400 Bad Request)
POST {{host}}/orders/update
Content-Type: application/json
Accept: application/json

{
    "state": "Draft",
    "assignedTo": "",
    "notes": "Empty assignedTo should fail validation"
}

### Update order — invalid state (400 Bad Request)
POST {{host}}/orders/update
Content-Type: application/json
Accept: application/json

{
    "state": "InvalidState",
    "notes": "This should fail"
}

###############################################################################
# Create Order (auto-validation of multiple value objects)
###############################################################################

### Create order with RequiredEnum + value objects (200 OK)
POST {{host}}/orders/create
Content-Type: application/json
Accept: application/json

{
    "customerFirstName": "John",
    "customerLastName": "Doe",
    "customerEmail": "john.doe@example.com",
    "initialState": "Draft"
}

### Create order — all fields invalid (400 Bad Request, errors collected)
POST {{host}}/orders/create
Content-Type: application/json
Accept: application/json

{
    "customerFirstName": "",
    "customerLastName": "",
    "customerEmail": "invalid-email",
    "initialState": "InvalidState"
}
