<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <RootNamespace>Trellis.Showcase.MinimalApi</RootNamespace>
    <!--
      AOT publish is enabled and gated in CI (see .github/workflows/build.yml).
      `dotnet publish -c Release -r <rid> /p:PublishAot=true` must produce zero IL warnings.
      The Showcase intentionally exercises Trellis.Asp + Trellis.FluentValidation + Trellis.Mediator
      under AOT to prove the framework's AOT story end-to-end. EF Core is not exercised here
      because Microsoft.EntityFrameworkCore is documented as not AOT-ready (see Trellis.EntityFrameworkCore README).
    -->
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Scalar.AspNetCore" />
    <PackageReference Include="Scalar.AspNetCore.Microsoft" />
    <PackageReference Include="Mediator.SourceGenerator">
      <OutputItemType>Analyzer</OutputItemType>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Showcase.Domain\Showcase.Domain.csproj" />
    <ProjectReference Include="..\Showcase.Application\Showcase.Application.csproj" />
    <ProjectReference Include="..\..\..\..\Trellis.Asp\src\Trellis.Asp.csproj" />
    <ProjectReference Include="..\..\..\..\Trellis.Mediator\src\Trellis.Mediator.csproj" />
    <ProjectReference Include="..\..\..\..\Trellis.FluentValidation\src\Trellis.FluentValidation.csproj" />
  </ItemGroup>

</Project>
